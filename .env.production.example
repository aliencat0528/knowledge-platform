# Knowledge Platform - Production Environment Variables
# Copy this file and set values in Zeabur Dashboard or your deployment platform

# ============================================
# Required Settings
# ============================================

# OpenAI API Key (Required for Chat and Embedding)
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# Optional Provider Settings
# ============================================

# Anthropic API Key (Optional, for Claude models)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Notion Integration (Optional, for syncing)
# NOTION_API_KEY=secret_your-notion-key
# NOTION_DATABASE_ID=your-database-id

# Ollama (Optional, for local models)
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# System Settings (Usually don't change)
# ============================================

# Environment
ENVIRONMENT=production
DEBUG=false

# Database paths (Zeabur volume mounted)
DATABASE_PATH=/app/data/knowledge.db
CHROMA_PATH=/app/data/chroma

# Server settings
HOST=0.0.0.0
PORT=8000

# ============================================
# Provider Selection
# ============================================

# LLM Provider: openai, anthropic, ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Embedding Provider: openai, ollama
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
