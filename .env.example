# Knowledge Platform - Environment Variables
# 複製此檔案為 .env 並填入實際值

# ============================================
# 基本設定（必要）
# ============================================

# 資料庫路徑
DATABASE_PATH=./data/knowledge.db

# 向量資料庫路徑
CHROMA_PATH=./data/chroma

# ============================================
# AI Provider 設定（語意搜尋 + Chat 需要）
# ============================================

# LLM Provider: openai / anthropic / ollama
LLM_PROVIDER=openai

# Embedding Provider: openai / ollama
EMBEDDING_PROVIDER=openai

# --- OpenAI 設定 ---
# 取得方式：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here
# 模型（LLM_PROVIDER=openai 時使用）
# LLM_MODEL=gpt-4o-mini

# --- Anthropic 設定 ---
# 取得方式：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# 模型（LLM_PROVIDER=anthropic 時使用）
# LLM_MODEL=claude-sonnet-4-20250514

# --- Ollama 設定（本地模型）---
# 安裝方式：https://ollama.ai/download
OLLAMA_BASE_URL=http://localhost:11434
# 模型（LLM_PROVIDER=ollama 時使用）
# LLM_MODEL=llama3.2

# --- 通用 LLM/Embedding 設定 ---
# LLM 模型（依 Provider 調整）
LLM_MODEL=gpt-4o-mini

# Embedding 模型（依 Provider 調整）
# OpenAI: text-embedding-3-small, text-embedding-3-large
# Ollama: nomic-embed-text, mxbai-embed-large
EMBEDDING_MODEL=text-embedding-3-small

# 自動向量化新匯入的文章
AUTO_EMBED=false

# ============================================
# Notion 同步設定（選用）
# ============================================

# Notion Integration API Key
# 建立方式：https://www.notion.so/my-integrations
NOTION_API_KEY=secret_your-notion-api-key

# 目標 Database ID
# 從 Database URL 取得：https://notion.so/<workspace>/<database_id>?v=...
NOTION_DATABASE_ID=your-database-id

# ============================================
# API 認證（部署到公網時必要）
# ============================================

# 所有 /api/v1/*（health 除外）要求請求帶 X-API-Key header
# 未設定時：development 放行（本機開發）、production 一律拒絕（fail closed）
# API_KEY=your-random-api-key

# ============================================
# 開發設定
# ============================================

# Debug 模式
DEBUG=true

# Log 等級
LOG_LEVEL=INFO

# 伺服器設定
HOST=127.0.0.1
PORT=8000
